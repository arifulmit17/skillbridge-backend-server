generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  Admin
  Tutor
  Student
}

enum Status {
  Unbanned
  Banned
}

model User {
    id        String   @id @default(uuid())
    name      String
    email     String   @unique
    password  String
    role      Role  @default(Student)
    status    Status @default(Unbanned)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    tutorProfile TutorProfile?
    @@index([status])
    @@map("users")
}

model TutorProfile{
   id String @id @default(uuid())
   subject String 
   isFeatured Boolean
   isBooked Boolean

   userid String @unique
   User User @relation(fields: [userid],references: [id])
   
}